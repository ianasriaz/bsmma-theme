{% schema %}
{
  "name": "Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest Drops"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 12,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Product Slider",
      "category": "Product"
    }
  ]
}
{% endschema %}

<section class="w-full bg-white py-16 md:py-24 border-t border-zinc-100">
  <div class="max-w-[1400px] mx-auto px-6">
    
    <div class="mb-12 text-center md:text-left">
      {% if section.settings.heading != blank %}
        <h2 class="font-display text-6xl md:text-8xl lg:text-[8rem] !font-black !text-zinc-950 uppercase tracking-tighter leading-none">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% assign target_collection = section.settings.collection %}
      {% if target_collection == blank %}
        {% assign target_collection = collections['all'] %}
      {% endif %}
    </div>

    <!-- Product Grid Container -->
    <div class="!grid !grid-cols-2 lg:!grid-cols-4 gap-4 md:gap-6 pb-8">
      
      {% if target_collection != blank and target_collection.products_count > 0 %}
        {% for product in target_collection.products limit: section.settings.products_to_show %}
          <div class="group relative bg-white border border-zinc-200 transition-all duration-300 hover:border-zinc-300 hover:shadow-md w-full">
            <!-- Product Image -->
            <a href="{{ product.url }}" class="block relative aspect-[3/4] overflow-hidden bg-zinc-100">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700', loading: 'lazy' }}
                
                {% if product.images[1] != blank %}
                  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-zinc-100">
                    {{ product.images[1] | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover object-center', loading: 'lazy' }}
                  </div>
                {% endif %}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover object-center opacity-50 !fill-zinc-400 group-hover:scale-105 transition-transform duration-700' }}
              {% endif %}

              <!-- Sale Badge -->
              {% if product.compare_at_price > product.price %}
                <span class="absolute top-4 left-4 bg-accent !text-white text-sm md:text-base font-bold px-4 py-2 uppercase tracking-widest shadow-lg">Sale</span>
              {% endif %}
            </a>

            <!-- Product Info -->
            <div class="p-6 md:p-8">
              <p class="text-zinc-500 text-xs md:text-sm font-bold uppercase tracking-widest mb-2 md:mb-3">{{ product.vendor }}</p>
              <h3 class="font-display text-lg sm:text-xl md:text-3xl lg:text-4xl font-normal !text-zinc-900 mb-2 md:mb-4 leading-tight md:leading-none uppercase tracking-tight">
                <a href="{{ product.url }}" class="hover:text-accent transition-colors">{{ product.title }}</a>
              </h3>
              
              <div class="flex flex-col xl:flex-row xl:items-center gap-1 xl:gap-4">
                <span class="!text-zinc-900 !font-black text-lg sm:text-xl md:text-3xl tracking-tighter">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="text-zinc-400 line-through text-base md:text-3xl !font-black tracking-tighter">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>

            <!-- Quick Add Button (Mockup / Link to Product) -->
            <a href="{{ product.url }}" class="absolute bottom-5 right-5 w-10 h-10 rounded-full bg-zinc-900 text-white flex items-center justify-center opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 hover:bg-accent">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            </a>
          </div>
        {% endfor %}
      {% else %}
        <!-- Placeholder Fallback -->
        {% for i in (1..section.settings.products_to_show) %}
          <div class="group relative bg-white border border-zinc-200 hover:border-zinc-300 hover:shadow-md transition-all duration-300 w-full">
            <div class="block relative aspect-[3/4] overflow-hidden bg-zinc-100">
              {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
              {{ 'product-' | append: current | placeholder_svg_tag: 'w-full h-full object-cover object-center opacity-40 !fill-zinc-300' }}
            </div>
            <div class="p-4 md:p-8">
              <p class="text-zinc-500 text-xs md:text-sm font-bold uppercase tracking-widest mb-2 md:mb-3">Vendor</p>
              <h3 class="font-display text-lg sm:text-xl md:text-3xl lg:text-4xl font-normal !text-zinc-900 mb-2 md:mb-4 leading-tight md:leading-none uppercase tracking-tight">Example Product {{ i }}</h3>
              <span class="!text-zinc-900 !font-black text-lg sm:text-xl md:text-3xl tracking-tighter">Rs. 5,000.00</span>
            </div>
          </div>
        {% endfor %}
      {% endif %}

    </div>

    {% if target_collection != blank %}
      <div class="flex justify-center mt-12">
        <a href="{{ target_collection.url }}" class="inline-flex items-center justify-center px-12 py-5 bg-transparent border-2 border-zinc-900 text-zinc-900 hover:border-accent hover:bg-accent hover:text-white font-bold uppercase tracking-widest transition-all duration-300 text-lg">
          View All Products
        </a>
      </div>
    {% endif %}
  </div>
</section>
