{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Marquee Text",
      "default": "PREMIUM QUALITY • FREE SHIPPING • SECURE PAYMENTS • EASY RETURNS • "
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation Speed (Seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "category": "Text"
    }
  ]
}
{% endschema %}

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee {{ section.settings.speed }}s linear infinite;
    display: flex;
    width: max-content;
  }
</style>

<section class="w-full overflow-hidden border-y border-zinc-800 py-4 flex items-center" style="background-color: {{ section.settings.bg_color }};">
  <div class="animate-marquee">
    <div class="flex shrink-0 px-4 whitespace-nowrap text-xl md:text-2xl font-display font-bold uppercase tracking-widest" style="color: {{ section.settings.text_color }};">
      {{ section.settings.text }}
    </div>
    <div class="flex shrink-0 px-4 whitespace-nowrap text-xl md:text-2xl font-display font-bold uppercase tracking-widest" style="color: {{ section.settings.text_color }};">
      {{ section.settings.text }}
    </div>
    <div class="flex shrink-0 px-4 whitespace-nowrap text-xl md:text-2xl font-display font-bold uppercase tracking-widest" style="color: {{ section.settings.text_color }};">
      {{ section.settings.text }}
    </div>
    <div class="flex shrink-0 px-4 whitespace-nowrap text-xl md:text-2xl font-display font-bold uppercase tracking-widest" style="color: {{ section.settings.text_color }};">
      {{ section.settings.text }}
    </div>
  </div>
</section>
