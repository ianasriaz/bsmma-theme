{% schema %}
{
  "name": "Collections Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Collections"
    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 12
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel",
      "category": "Collection"
    }
  ]
}
{% endschema %}

<section class="w-full bg-black py-16 md:py-24">
  <div class="max-w-[1400px] mx-auto px-6">
    {% if section.settings.heading != blank %}
      <h2 class="font-display text-6xl md:text-8xl lg:text-[8rem] !font-black !text-white uppercase tracking-tighter mb-16 text-center drop-shadow-md leading-none">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <!-- Carousel Container -->
    <div class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar gap-6 pb-8" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">
      
      {% if section.settings.collection_list != blank %}
        {% for collection in section.settings.collection_list %}
          <a href="{{ collection.url }}" class="group relative flex-none w-[280px] md:w-[350px] aspect-[4/5] snap-start overflow-hidden bg-zinc-900 border border-zinc-800 transition-transform duration-500 hover:-translate-y-2">
            <!-- Collection Image -->
            {% if collection.image != blank %}
              {{ collection.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover object-center opacity-80 group-hover:opacity-100 transition-opacity duration-500 group-hover:scale-110', loading: 'lazy' }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover object-center opacity-50 !fill-zinc-700 group-hover:scale-110 transition-transform duration-500' }}
            {% endif %}

            <!-- Overlay Gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

            <!-- Collection Title -->
            <div class="absolute bottom-6 left-6 right-6 flex items-center justify-between">
              <h3 class="font-display text-2xl font-bold text-white uppercase tracking-wider group-hover:text-accent transition-colors duration-300">
                {{ collection.title }}
              </h3>
              <span class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white group-hover:bg-accent group-hover:text-white transition-colors duration-300 backdrop-blur-sm">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <!-- Placeholder Fallback if no collections selected -->
        {% for i in (1..5) %}
          <a href="#" class="group relative flex-none w-[280px] md:w-[350px] aspect-[4/5] snap-start overflow-hidden bg-zinc-900 border border-zinc-800">
            {% capture current %}{% cycle 1, 2, 3, 4, 5 %}{% endcapture %}
            {{ 'collection-' | append: current | placeholder_svg_tag: 'w-full h-full object-cover object-center opacity-50 !fill-zinc-700' }}
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
            <div class="absolute bottom-8 left-8">
              <h3 class="font-display text-3xl font-black !text-white uppercase tracking-widest group-hover:text-accent transition-colors">
                Collection {{ i }}
              </h3>
            </div>
          </a>
        {% endfor %}
      {% endif %}

    </div>
  </div>
</section>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
