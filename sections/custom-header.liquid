{% doc %}
  Renders the store's topbar (announcement strip) and main header, with a
  full-height drawer menu triggered by the hamburger icon. Topbar and header
  stick together to the top of the viewport on scroll.

  @example
  {% section 'custom-header' %}
{% enddoc %}

{% liquid
  assign cart_count = cart.item_count
%}
<!-- Header Sticky Wrapper Removed (Handled in theme.liquid) -->

  <!-- Main Header -->
  <header class="w-full bg-surface text-text-main border-b border-border relative">
    <div class="w-full max-w-[1400px] mx-auto h-24 md:h-32 px-4 md:px-6 flex justify-between items-center">

      <!-- Left: Menu trigger -->
      <div class="flex-1 flex items-center justify-start">
        <button
          type="button"
          class="relative inline-flex items-center justify-center gap-3 md:gap-4 h-12 md:h-14 text-text-main bg-transparent border-none cursor-pointer hover:opacity-60 transition-opacity js-menu-toggle group"
          aria-haspopup="dialog"
          aria-controls="site-menu-drawer"
          aria-expanded="false"
        >
          <span class="flex flex-col justify-center gap-[6px] md:gap-[8px] w-6 md:w-8" aria-hidden="true">
            <span class="block h-[2px] md:h-[2px] w-full bg-current rounded-full transition-all duration-200 group-aria-expanded:translate-y-[8px] md:group-aria-expanded:translate-y-[10px] group-aria-expanded:rotate-45"></span>
            <span class="block h-[2px] md:h-[2px] w-full bg-current rounded-full transition-all duration-200 group-aria-expanded:opacity-0"></span>
            <span class="block h-[2px] md:h-[2px] w-full bg-current rounded-full transition-all duration-200 group-aria-expanded:-translate-y-[8px] md:group-aria-expanded:-translate-y-[10px] group-aria-expanded:-rotate-45"></span>
          </span>
          <span class="hidden md:inline-block font-display font-black text-lg md:text-xl tracking-wide uppercase">{{ 'sections.custom_header.menu' | t }}</span>
        </button>
      </div>

      <!-- Center: Wordmark -->
      <div class="flex items-center justify-center">
        <a href="{{ routes.root_url }}" class="font-sans text-xl md:text-[2.5rem] !font-bold tracking-tight uppercase text-text-main no-underline whitespace-nowrap transition-opacity hover:opacity-60">
          {% if section.settings.logo_text != blank %}
            {{ section.settings.logo_text }}
          {% else %}
            {{ 'sections.custom_header.logo_default' | t }}
          {% endif %}
        </a>
      </div>

      <!-- Right: Actions -->
      <div class="flex-1 flex items-center justify-end gap-2 md:gap-7 !static">
        <details-modal class="header__search !static">
          <details class="!static">
            <summary class="relative inline-flex items-center justify-center w-10 h-10 md:w-14 md:h-14 text-text-main hover:opacity-60 transition-opacity cursor-pointer list-none [&::-webkit-details-marker]:hidden" aria-haspopup="dialog" aria-label="{{ 'sections.custom_header.search' | t }}">
              <span class="w-6 h-6 md:w-8 md:h-8 transition-opacity duration-200 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current [&>svg]:scale-[1.3] [&>svg]:stroke-current [&>svg]:stroke-[0.2]">
                {{ 'icon-search.svg' | inline_asset_content }}
              </span>
            </summary>
            <div class="search-modal modal__content gradient !fixed !left-0 !right-0 !w-[100vw] !max-w-[100vw] !mt-8 !h-auto !min-h-0 border-t-2 border-border bg-surface shadow-2xl z-50" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}">
              <div class="modal-overlay !hidden"></div>
              <div class="search-modal__content !py-8 md:!py-12 max-w-4xl mx-auto px-4 w-full flex items-center justify-center relative" tabindex="-1">
                {%- if settings.predictive_search_enabled -%}
                  <predictive-search class="search-modal__form w-full" data-loading-text="{{ 'accessibility.loading' | t }}">
                {%- else -%}
                  <search-form class="search-modal__form w-full">
                {%- endif -%}
                <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form w-full relative flex items-center">
                  <div class="relative w-full flex items-center border-2 border-text-main rounded-none bg-background overflow-hidden group focus-within:border-accent transition-colors">
                    <button class="search__button w-14 h-14 flex items-center justify-center text-text-main group-focus-within:text-accent transition-colors shrink-0" aria-label="{{ 'general.search.search' | t }}">
                      <span class="w-6 h-6 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current [&>svg]:scale-[1.3] [&>svg]:stroke-current [&>svg]:stroke-[0.2]">
                        {{- 'icon-search.svg' | inline_asset_content -}}
                      </span>
                    </button>
                    
                    <input class="search__input w-full h-14 bg-transparent border-none outline-none text-xl md:text-2xl font-semibold text-text-main placeholder:text-text-main/40 px-2" id="Search-In-Modal" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.search' | t }}" {%- if settings.predictive_search_enabled -%} role="combobox" aria-expanded="false" aria-owns="predictive-search-results" aria-controls="predictive-search-results" aria-haspopup="listbox" aria-autocomplete="list" autocorrect="off" autocomplete="off" autocapitalize="off" spellcheck="false" {%- endif -%}>
                    <input type="hidden" name="options[prefix]" value="last">
                    
                    <button type="reset" class="reset__button w-14 h-14 flex items-center justify-center text-text-main hover:text-accent transition-colors shrink-0 {% if search.terms == blank %} hidden{% endif %}" aria-label="{{ 'general.search.reset' | t }}">
                      <span class="w-5 h-5 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current">
                        {{- 'icon-reset.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  </div>

                  {%- if settings.predictive_search_enabled -%}
                    <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
                      {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
                    </div>
                    <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                  {%- endif -%}
                </form>
                {%- if settings.predictive_search_enabled -%}
                  </predictive-search>
                {%- else -%}
                  </search-form>
                {%- endif -%}
                <button type="button" class="search-modal__close-button absolute top-4 right-4 md:top-6 md:right-6 w-10 h-10 flex items-center justify-center text-text-main hover:text-accent transition-colors bg-surface hover:bg-surface-subdued rounded-full" aria-label="{{ 'accessibility.close' | t }}">
                  <span class="w-5 h-5 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current">
                    {{- 'icon-close.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
            </div>
          </details>
        </details-modal>

        <a href="{{ routes.account_url }}" class="hidden md:inline-flex relative items-center justify-center w-12 h-12 md:w-14 md:h-14 text-text-main hover:opacity-60 transition-opacity" aria-label="{{ 'sections.custom_header.account' | t }}">
          <span class="w-6 h-6 md:w-8 md:h-8 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current [&>svg]:scale-[1.3] [&>svg]:stroke-current [&>svg]:stroke-[0.2]">
            {{ 'icon-account.svg' | inline_asset_content }}
          </span>
        </a>

        <a href="{{ routes.cart_url }}" id="cart-icon-bubble" class="relative inline-flex items-center justify-center w-10 h-10 md:w-14 md:h-14 text-text-main hover:opacity-60 transition-opacity" aria-label="{{ 'sections.custom_header.cart' | t }}">
          <span class="w-6 h-6 md:w-8 md:h-8 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current [&>svg]:scale-[2.4] [&>svg]:stroke-current [&>svg]:stroke-[0.5]">
            {% if cart == empty %}
              {{ 'icon-cart-empty.svg' | inline_asset_content }}
            {% else %}
              {{ 'icon-cart.svg' | inline_asset_content }}
            {% endif %}
          </span>
          {% if cart_count > 0 %}
            <span class="absolute top-[2px] right-[2px] min-w-[1.4rem] h-[1.4rem] px-1 bg-accent text-surface text-[0.8rem] md:text-[0.9rem] font-black leading-[1.4rem] text-center rounded-full">{{ cart_count }}</span>
          {% endif %}
        </a>
      </div>

    </div>
  </header>

</div>

<!-- Drawer Menu -->
<style>
  @keyframes slideUpFade {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .js-menu-drawer[data-drawer-state="open"] .menu-item-anim {
    animation: slideUpFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
<div
  id="site-menu-drawer"
  class="fixed inset-0 z-[100] hidden js-menu-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'sections.custom_header.menu' | t }}"
>
  <div class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-500 ease-out js-menu-overlay [[data-drawer-state=open]_&]:opacity-100 backdrop-blur-sm"></div>

  <div class="absolute top-0 left-0 h-full w-[min(90vw,450px)] bg-surface text-text-main flex flex-col -translate-x-full transition-transform duration-500 cubic-bezier(0.16, 1, 0.3, 1) ease-out [[data-drawer-state=open]_&]:translate-x-0 shadow-2xl border-r border-border/10">
    <div class="flex items-center justify-between p-6 md:p-8 border-b border-border/10">
      <span class="text-sm font-black tracking-widest uppercase text-text-main/50">{{ 'sections.custom_header.menu' | t }}</span>
      <button type="button" class="relative inline-flex items-center justify-center w-12 h-12 text-text-main hover:text-accent hover:rotate-90 transition-all duration-300 js-menu-close" aria-label="{{ 'sections.custom_header.close' | t }}">
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto p-6 md:p-8">
      <ul class="list-none m-0 p-0 flex flex-col gap-2" role="list">
        {% assign header_menu = section.settings.menu | default: linklists['main-menu'] %}
        {% for link in header_menu.links %}
          <li class="menu-item-anim opacity-0 border-b border-border/5 last:border-b-0 overflow-hidden" style="animation-delay: {{ forloop.index | times: 0.08 }}s;">
            {% if link.links != blank %}
              <details class="group/details">
                <summary class="group flex items-center justify-between py-4 text-3xl md:text-5xl font-display font-black uppercase tracking-tighter text-text-main no-underline transition-colors hover:text-accent cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span class="transition-transform duration-300 group-hover:translate-x-4">{{ link.title }}</span>
                  <span class="w-8 h-8 md:w-10 md:h-10 text-text-main flex items-center justify-center transition-transform duration-300 group-open/details:rotate-180">
                    <svg class="w-6 h-6 md:w-8 md:h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </span>
                </summary>
                <ul class="pl-4 md:pl-8 pb-4 flex flex-col gap-3">
                  {% for child_link in link.links %}
                    <li>
                      {% if child_link.links != blank %}
                        <details class="group/subdetails">
                          <summary class="flex items-center justify-between py-2 text-xl md:text-2xl font-sans font-bold uppercase tracking-widest text-text-main/80 hover:text-accent transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                            <span>{{ child_link.title }}</span>
                            <span class="transition-transform duration-300 group-open/subdetails:rotate-180">
                              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                          </summary>
                          <ul class="pl-4 md:pl-6 pt-2 pb-2 flex flex-col gap-2">
                            {% for grandchild_link in child_link.links %}
                              <li>
                                <a href="{{ grandchild_link.url }}" class="block py-1 text-base md:text-lg font-sans font-semibold uppercase tracking-wider text-text-main/60 hover:text-accent transition-colors {% if grandchild_link.active %}text-accent{% endif %}">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        </details>
                      {% else %}
                        <a href="{{ child_link.url }}" class="block py-2 text-xl md:text-2xl font-sans font-bold uppercase tracking-widest text-text-main/80 hover:text-accent transition-colors {% if child_link.active %}text-accent{% endif %}">
                          {{ child_link.title }}
                        </a>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              </details>
            {% else %}
              <a href="{{ link.url }}" class="group flex items-center justify-between py-4 text-3xl md:text-5xl font-display font-black uppercase tracking-tighter text-text-main no-underline transition-colors hover:text-accent {% if link.active %}text-accent{% endif %}">
                <span class="transition-transform duration-300 group-hover:translate-x-4">{{ link.title }}</span>
                <span class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-accent/10 text-accent flex items-center justify-center opacity-0 -translate-x-8 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
                  <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7l7 7-7 7"/></svg>
                </span>
              </a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="flex flex-col gap-4 p-6 md:p-8 bg-text-main/5 border-t border-border/10">
      <a href="{{ routes.account_url }}" class="flex items-center gap-4 text-sm font-black tracking-widest uppercase text-text-main no-underline hover:text-accent transition-colors group">
        <span class="w-10 h-10 flex items-center justify-center bg-surface rounded-full shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
        </span>
        {{ 'sections.custom_header.account' | t }}
      </a>
    </div>
  </div>

{% javascript %}
  (function () {
    var toggle = document.querySelector('.js-menu-toggle');
    var drawer = document.querySelector('.js-menu-drawer');
    var overlay = drawer ? drawer.querySelector('.js-menu-overlay') : null;
    var closeBtn = drawer ? drawer.querySelector('.js-menu-close') : null;

    if (!toggle || !drawer) return;

    function openDrawer() {
      drawer.classList.remove('hidden');
      requestAnimationFrame(function () {
        drawer.setAttribute('data-drawer-state', 'open');
      });
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      if (closeBtn) closeBtn.focus();
    }

    function closeDrawer() {
      drawer.removeAttribute('data-drawer-state');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      window.setTimeout(function () {
        drawer.classList.add('hidden');
      }, 300);
      toggle.focus();
    }

    toggle.addEventListener('click', function () {
      var isOpen = drawer.hasAttribute('data-drawer-state');
      if (isOpen) {
        closeDrawer();
      } else {
        openDrawer();
      }
    });

    if (overlay) overlay.addEventListener('click', closeDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && drawer.hasAttribute('data-drawer-state')) {
        closeDrawer();
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.custom_header.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "t:sections.custom_header.settings.announcement_text.label",
      "default": "Summer collection is now live. Shop new arrivals."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:sections.custom_header.settings.logo_text.label",
      "default": "Brand Store MM Alam"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.custom_header.settings.menu.label",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom_header.name"
    }
  ]
}
{% endschema %}